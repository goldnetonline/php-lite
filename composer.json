{
    "name": "goldnetonline/php-lite",
    "description": "Lightweight PHP starter project for small websites.",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.4 <9.0",
        "goldnetonline/php-lite-core": "^1.0@dev",
        "vlucas/phpdotenv": "^5.6",
        "nyholm/psr7": "^1.8"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^12.0"
    },
    "scripts": {
        "test": "phpunit --configuration phpunit.xml"
    }
}
